{
  "name": "recallant",
  "version": "0.0.0",
  "private": true,
  "description": "Governed memory for AI agents.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "db:down": "make db-down",
    "db:migrate": "make db-migrate",
    "db:reset": "make db-reset",
    "db:up": "make db-up",
    "format": "prettier --write \"{apps,packages}/**/*.{ts,json}\" \"*.{js,json}\" \".github/**/*.yml\"",
    "format:check": "prettier --check \"{apps,packages}/**/*.{ts,json}\" \"*.{js,json}\" \".github/**/*.yml\"",
    "lint": "eslint .",
    "server:start": "node apps/server/dist/index.js",
    "smoke:core": "npm run mcp:smoke && npm run phase3:smoke && npm run phase4:smoke && npm run phase5:smoke && npm run phase6:smoke:governed && npm run phase6:smoke:graph && npm run review-ui:smoke && npm run phase7:smoke && npm run prepilot:smoke:discovery && npm run prepilot:smoke:import && npm run prepilot:smoke:sandbox && npm run phase10:smoke && npm run phase8:smoke:backup && npm run phase8:smoke:limits && npm run phase8:smoke:errors && npm run phase8:smoke:search-p95 && npm run phase9:smoke:archive && npm run phase9:smoke:decay && npm run phase9:smoke:cleanup && npm run repo-contract:smoke && npm run spool:smoke && npm run product-acceptance:smoke && npm run local-cleanup:smoke && npm run cross-client:smoke",
    "mcp:smoke": "node scripts/smoke-mcp.mjs",
    "phase4:smoke": "node scripts/smoke-phase4-embeddings.mjs",
    "phase5:smoke": "node scripts/smoke-phase5-retrieval.mjs",
    "phase6:smoke:governed": "node scripts/smoke-phase6-governed-memory.mjs",
    "phase6:smoke:graph": "node scripts/smoke-phase6-graph-context-forget.mjs",
    "review-ui:smoke": "node scripts/smoke-review-ui.mjs",
    "phase8:smoke:backup": "node scripts/smoke-phase8-backup.mjs",
    "phase8:smoke:errors": "node scripts/smoke-phase8-errors-rate-limit.mjs",
    "phase8:smoke:limits": "node scripts/smoke-phase8-size-limits.mjs",
    "phase8:smoke:search-p95": "node scripts/smoke-phase8-search-p95.mjs",
    "phase9:smoke:archive": "node scripts/smoke-phase9-archive.mjs",
    "phase9:smoke:cleanup": "node scripts/smoke-phase9-cleanup.mjs",
    "phase9:smoke:decay": "node scripts/smoke-phase9-decay-supersedes.mjs",
    "repo-contract:smoke": "node scripts/smoke-repo-contract.mjs",
    "spool:smoke": "node scripts/smoke-spool.mjs",
    "agent-capture:smoke": "node scripts/smoke-agent-capture.mjs",
    "product-acceptance:smoke": "node scripts/smoke-agent-capture.mjs",
    "local-cleanup:smoke": "node scripts/smoke-local-cleanup.mjs",
    "cross-client:smoke": "node scripts/smoke-cross-client.mjs",
    "prepilot:smoke:discovery": "node scripts/smoke-pre-pilot-discovery.mjs",
    "prepilot:smoke:import": "node scripts/smoke-pre-pilot-import.mjs",
    "prepilot:smoke:sandbox": "node scripts/smoke-pre-pilot-sandbox.mjs",
    "phase10:smoke": "node scripts/smoke-phase10-attach.mjs && node scripts/smoke-phase10-detach.mjs && node scripts/smoke-phase10-cross-project.mjs",
    "phase7:smoke": "node scripts/smoke-phase7-cli.mjs",
    "phase3:smoke": "node scripts/smoke-phase3-db.mjs",
    "test": "npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/node": "^20.17.50",
    "eslint": "^9.27.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1"
  }
}
